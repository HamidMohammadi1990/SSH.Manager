<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BgDark">#1E1E2E</Color>
    <Color x:Key="BgMedium">#252536</Color>
    <Color x:Key="BgLight">#2D2D44</Color>
    <Color x:Key="BgCard">#313145</Color>
    <Color x:Key="Accent">#7C4DFF</Color>
    <Color x:Key="AccentLight">#B388FF</Color>
    <Color x:Key="TextPrimary">#E8E8F0</Color>
    <Color x:Key="TextSecondary">#A0A0B8</Color>
    <Color x:Key="Border">#3D3D55</Color>
    <Color x:Key="Success">#4CAF50</Color>
    <Color x:Key="Error">#F44336</Color>
    <Color x:Key="Warning">#FFC107</Color>

    <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
    <SolidColorBrush x:Key="BgMediumBrush" Color="{StaticResource BgMedium}"/>
    <SolidColorBrush x:Key="BgLightBrush" Color="{StaticResource BgLight}"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLight}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}"/>

    <FontFamily x:Key="MainFont">Segoe UI</FontFamily>
    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas, Courier New</FontFamily>

</ResourceDictionary>
