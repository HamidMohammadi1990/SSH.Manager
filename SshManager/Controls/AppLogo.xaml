<UserControl x:Class="SshManager.Controls.AppLogo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="32" Height="32">
    <Viewbox Stretch="Uniform">
        <Canvas Width="64" Height="64">
            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="56" Height="56" RadiusX="12" RadiusY="12">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1E1E2E" Offset="0"/>
                        <GradientStop Color="#141422" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.Stroke>
                    <SolidColorBrush Color="#7C4DFF" Opacity="0.45"/>
                </Rectangle.Stroke>
            </Rectangle>

            <Rectangle Canvas.Left="14" Canvas.Top="16" Width="36" Height="26" RadiusX="5" RadiusY="5" Fill="#252536"/>

            <Ellipse Canvas.Left="18" Canvas.Top="20" Width="5" Height="5" Fill="#7C4DFF"/>
            <Ellipse Canvas.Left="25" Canvas.Top="20" Width="5" Height="5" Fill="#FFC107"/>
            <Ellipse Canvas.Left="32" Canvas.Top="20" Width="5" Height="5" Fill="#4CAF50"/>

            <Path Stroke="#B388FF" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 18,31 L 34,31"/>
            <Path Stroke="#A0A0B8" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 18,37 L 40,37"/>
            <Path Stroke="#A0A0B8" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Opacity="0.7"
                  Data="M 18,42 L 30,42"/>

            <Path Stroke="#7C4DFF" StrokeThickness="2.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                  Data="M 16,50 L 32,46 L 48,50"/>
            <Ellipse Canvas.Left="12" Canvas.Top="46" Width="8" Height="8" Fill="#B388FF"/>
            <Ellipse Canvas.Left="28" Canvas.Top="42" Width="8" Height="8" Fill="#B388FF"/>
            <Ellipse Canvas.Left="44" Canvas.Top="46" Width="8" Height="8" Fill="#B388FF"/>
        </Canvas>
    </Viewbox>
</UserControl>
