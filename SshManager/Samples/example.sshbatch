# SSH Manager batch job example
# Multiple @steps blocks are merged in order.

@credential
user.name=admin
user.password=your-login-password
enable.password=your-enable-password

@defaults
type=telnet
port=23
delay=500

@targets
192.168.1.2
192.168.1.3

@steps
en
<password>
conf t

@steps
sh run
wr
<enter>
