<Window x:Class="SshManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SshManager.ViewModels"
        xmlns:controls="clr-namespace:SshManager.Controls"
        xmlns:views="clr-namespace:SshManager.Views"
        Title="SSH Manager"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BgDarkBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource BgMediumBrush}" Padding="20,14"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <controls:AppLogo Width="28" Height="28" Margin="0,0,10,0"/>
                    <TextBlock Text="SSH Manager" FontSize="20" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDate}" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="12" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentTime}" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="22" FontWeight="Light" HorizontalAlignment="Center" FontFamily="{DynamicResource MonoFont}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="⚙ Settings" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"
                            Command="{Binding OpenSettingsCommand}"/>
                    <Button Content="💾 Save" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"
                            Command="{Binding SaveCommand}"
                            ToolTip="Save servers, groups, and settings to disk (%AppData%\SshManager\data.json)"/>
                    <Button Content="📤 Export" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"
                            Command="{Binding ExportDataCommand}"/>
                    <Button Content="📥 Import" Style="{DynamicResource SecondaryButton}"
                            Command="{Binding ImportDataCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*" MinWidth="350"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="380" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Servers Panel -->
            <Border Grid.Column="0" Background="{DynamicResource BgMediumBrush}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Groups" Style="{DynamicResource SectionTitle}"/>
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="+ Add Group" Style="{DynamicResource PrimaryButton}" Margin="0,0,4,0"
                                    Command="{Binding AddGroupCommand}"/>
                            <Button Content="Remove" Style="{DynamicResource DangerButton}"
                                    Command="{Binding RemoveGroupCommand}"/>
                        </StackPanel>
                        <TextBlock Text="Select Group" Style="{DynamicResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding Groups}"
                                  SelectedItem="{Binding SelectedGroup}"
                                  DisplayMemberPath="Name" Margin="0,0,0,8"/>
                        <TextBlock Text="Group Name" Style="{DynamicResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedGroup.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,4" TextChanged="GroupField_Changed"
                                 IsEnabled="{Binding SelectedGroup, Converter={StaticResource ObjectToBool}}"/>
                        <TextBlock Text="Edit name, then click Save" Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="10" Margin="0,0,0,4"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding ServersListTitle}" Style="{DynamicResource SectionTitle}"/>
                        <ListBox x:Name="ServerListBox" Grid.Row="1" ItemsSource="{Binding ServersView}"
                                 SelectedItem="{Binding SelectedServer}"
                                 PreviewMouseLeftButtonDown="ServerList_PreviewMouseLeftButtonDown"
                                 PreviewMouseRightButtonDown="ServerList_PreviewMouseRightButtonDown">
                            <ListBox.ContextMenu>
                                <ContextMenu Style="{DynamicResource DarkContextMenu}"
                                             DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="View Details" Style="{DynamicResource DarkMenuItem}"
                                              Click="ViewDetailsMenuItem_Click"/>
                                    <Separator Style="{DynamicResource DarkMenuSeparator}"/>
                                    <MenuItem Header="Remove Server" Style="{DynamicResource DarkMenuItem}"
                                              Command="{Binding RemoveServerCommand}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                 Fill="{Binding ConnectionStatus, Converter={StaticResource StatusBrush}}"/>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11">
                                                <Run Text="{Binding Host, Mode=OneWay}"/>
                                                <Run Text=":"/>
                                                <Run Text="{Binding Port, Mode=OneWay}"/>
                                                <Run Text=" • "/>
                                                <Run Text="{Binding ConnectionType, Converter={StaticResource ConnTypeStr}, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Commands.Count, StringFormat={}{0} cmd}"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <StackPanel Grid.Row="3" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="+ Add" Style="{DynamicResource PrimaryButton}" Margin="0,0,4,0"
                                    Command="{Binding AddServerCommand}"/>
                            <Button Content="▲" Style="{DynamicResource IconButton}" Command="{Binding MoveServerUpCommand}" ToolTip="Move Up"/>
                            <Button Content="▼" Style="{DynamicResource IconButton}" Command="{Binding MoveServerDownCommand}" ToolTip="Move Down"/>
                        </StackPanel>
                        <Button Content="🔍 Test All Connections" Style="{DynamicResource SecondaryButton}"
                                Command="{Binding TestAllConnectionsCommand}"
                                IsEnabled="{Binding IsTestingConnections, Converter={StaticResource InverseBool}}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource BorderBrush}"/>

            <!-- Center: Server Tabs -->
            <Grid Grid.Column="2" Background="{DynamicResource BgMediumBrush}">
                <TabControl ItemsSource="{Binding OpenServerTabs}"
                            SelectedItem="{Binding SelectedTab}"
                            Style="{StaticResource ServerTabControl}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0">
                    <TabControl.Resources>
                        <Style TargetType="TabItem" BasedOn="{StaticResource ServerTabItem}">
                            <Setter Property="HeaderTemplate">
                                <Setter.Value>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button Content="✕" Style="{DynamicResource IconButton}"
                                                    Padding="4,2" MinWidth="22" Height="22" FontSize="10"
                                                    ToolTip="Close tab"
                                                    Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TabControl.Resources>
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <views:ServerEditorView DataContext="{Binding Server}"
                                                    VerticalAlignment="Stretch"
                                                    HorizontalAlignment="Stretch"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <TextBlock Text="Click + Add to open a server tab, or select a server from the list"
                           Foreground="{DynamicResource TextSecondaryBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding HasOpenTabs, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}"/>
            </Grid>

            <Border Grid.Column="3" Background="{DynamicResource BorderBrush}"/>

            <!-- Right: Execution Panel -->
            <Border Grid.Column="4" Background="{DynamicResource BgMediumBrush}" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Execution" Style="{DynamicResource SectionTitle}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="▶ Run All" Style="{DynamicResource PrimaryButton}" Margin="0,0,8,0"
                                Command="{Binding ExecuteAllCommand}"
                                IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBool}}"/>
                        <Button Content="⏹ Cancel" Style="{DynamicResource DangerButton}" Margin="0,0,8,0"
                                Command="{Binding CancelExecutionCommand}"
                                Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVis}}"/>
                        <Button Content="Clear" Style="{DynamicResource SecondaryButton}"
                                Command="{Binding ClearOutputCommand}"/>
                    </StackPanel>

                    <Border Grid.Row="2" Background="{DynamicResource BgCardBrush}" CornerRadius="8"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Padding="12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Batch Jobs" Style="{DynamicResource SectionTitle}" Margin="0,0,0,10"/>
                            <TextBlock Text="Run command scripts from a .sshbatch file on multiple targets."
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                       TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="Protocol" Style="{DynamicResource FieldLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
                                <RadioButton GroupName="BatchProtocol" Content="Telnet · 23"
                                             IsChecked="{Binding IsBatchTelnet}" Margin="0,0,16,0"
                                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                                <RadioButton GroupName="BatchProtocol" Content="SSH · 22"
                                             IsChecked="{Binding IsBatchSsh}"
                                             Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="📂 Load Batch" Style="{DynamicResource SecondaryButton}" Margin="0,0,8,0"
                                        Command="{Binding LoadBatchCommand}"
                                        IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBool}}"/>
                                <Button Content="▶ Run Batch" Style="{DynamicResource PrimaryButton}"
                                        Command="{Binding ExecuteBatchCommand}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding LoadedBatchSummary}" FontSize="11" Margin="0,10,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding HasLoadedBatch, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <TabControl Grid.Row="3">
                        <TabItem Header="Live Output">
                            <ListBox ItemsSource="{Binding OutputLines}"
                                     Style="{StaticResource OutputListBox}"
                                     FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                     Background="{DynamicResource BgDarkBrush}" Margin="0,8,0,0">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock TextWrapping="NoWrap">
                                            <Run Text="{Binding Timestamp, StringFormat='[{0:HH:mm:ss}] ', Mode=OneWay}"
                                                 Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Text, Mode=OneWay}"/>
                                        </TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="Results">
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                                <ItemsControl ItemsSource="{Binding ExecutionResults}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander IsExpanded="{Binding IsExpanded}" Margin="0,0,0,6">
                                                <Expander.Header>
                                                    <Grid Width="300">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="10"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                                 Fill="{Binding Status, Converter={StaticResource ExecStatusBrush}}"/>
                                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding ServerName}" FontWeight="SemiBold" FontSize="12"/>
                                                            <TextBlock Text="{Binding GroupName}" FontSize="10"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" FontSize="11"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   Text="{Binding Duration, Converter={StaticResource TimeSpanStr}}"/>
                                                    </Grid>
                                                </Expander.Header>
                                                <ItemsControl ItemsSource="{Binding Commands}" Margin="16,4,0,4">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="{DynamicResource BgCardBrush}" CornerRadius="6"
                                                                    Padding="10" Margin="0,0,0,4">
                                                                <StackPanel>
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="10"/>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Ellipse Width="6" Height="6" VerticalAlignment="Center"
                                                                                 Fill="{Binding Status, Converter={StaticResource ExecStatusBrush}}"/>
                                                                        <TextBlock Grid.Column="1" Text="{Binding CommandText}"
                                                                                   FontFamily="{DynamicResource MonoFont}" FontSize="11"
                                                                                   Margin="6,0,0,0" TextWrapping="Wrap"/>
                                                                        <TextBlock Grid.Column="2" FontSize="10"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   Text="{Binding Duration, Converter={StaticResource TimeSpanStr}}"/>
                                                                    </Grid>
                                                                    <TextBlock Text="{Binding ErrorMessage}" Foreground="#F44336"
                                                                               FontSize="11" Margin="16,4,0,0" TextWrapping="Wrap"
                                                                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToVis}}"/>
                                                                    <TextBlock Text="{Binding Output}" FontFamily="{DynamicResource MonoFont}"
                                                                               FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                                               Margin="16,4,0,0" TextWrapping="Wrap" MaxHeight="120"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>

                    <Border Grid.Row="4" Background="{DynamicResource BgCardBrush}" CornerRadius="6" Padding="10" Margin="0,8,0,0"
                            Visibility="{Binding HasExecutionResults, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding ExecutionSummary}" FontSize="12"
                                   Foreground="{DynamicResource TextPrimaryBrush}" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource BgMediumBrush}" Padding="16,8"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" Margin="0,0,16,0">
                        <Run Text="Servers: "/>
                        <Run Text="{Binding Servers.Count, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Foreground="{DynamicResource AccentLightBrush}" FontSize="12"
                               Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVis}}">
                        <Run Text="● Executing..."/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
