<UserControl x:Class="SshManager.Views.ServerEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch"
             HorizontalAlignment="Stretch">
    <ScrollViewer Style="{DynamicResource ModernScrollViewer}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch">
        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Name" Style="{DynamicResource FieldLabel}"/>
                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource FormTextBox}"
                             TextChanged="ServerField_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Group" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding DataContext.GroupOptionsList, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedValue="{Binding GroupId}" SelectedValuePath="Id"
                              DisplayMemberPath="Name" Style="{DynamicResource FormComboBox}"
                              SelectionChanged="ServerField_Changed"/>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Host / IP" Style="{DynamicResource FieldLabel}"/>
                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource FormTextBox}"
                             TextChanged="ServerField_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Port" Style="{DynamicResource FieldLabel}"/>
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource FormTextBox}"
                             TextChanged="ServerField_Changed"/>
                </StackPanel>
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Type" Style="{DynamicResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding DataContext.ConnectionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding ConnectionType}" Style="{DynamicResource FormComboBox}"
                              SelectionChanged="ServerField_Changed">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Path=., Converter={StaticResource ConnTypeStr}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="Description" Style="{DynamicResource FieldLabel}"/>
                <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Style="{DynamicResource FormTextBox}"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="56" MaxHeight="80"
                         VerticalContentAlignment="Top"
                         VerticalScrollBarVisibility="Auto"
                         TextChanged="ServerField_Changed"/>
                <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,6,0,0">
                    <Run Text="Created: "/>
                    <Run Text="{Binding CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm}', Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <Border Grid.Row="3" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Targets" Style="{DynamicResource SectionTitle}" Margin="0,0,0,8"/>
                    <TextBlock Text="Run All executes commands on each target. If empty, Host / IP is used."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,8"/>
                    <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="8" Padding="4"
                            MinHeight="80" MaxHeight="140">
                        <ListBox x:Name="TargetListBox" ItemsSource="{Binding Targets}"
                                 SelectedItem="{Binding DataContext.SelectedTarget, RelativeSource={RelativeSource AncestorType=Window}}"
                                 Style="{DynamicResource FlatListBox}"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Host, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent" BorderThickness="0"
                                             FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                             MinHeight="28" Padding="4,6"
                                             TextChanged="TargetField_Changed"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Add" Style="{DynamicResource PrimaryButton}" Margin="0,0,4,0"
                                Command="{Binding DataContext.AddTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="Remove" Style="{DynamicResource DangerButton}" Margin="0,0,4,0"
                                Command="{Binding DataContext.RemoveTargetCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="▲" Style="{DynamicResource IconButton}"
                                Command="{Binding DataContext.MoveTargetUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        <Button Content="▼" Style="{DynamicResource IconButton}"
                                Command="{Binding DataContext.MoveTargetDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Background="{DynamicResource BgCardBrush}" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                <StackPanel>
                    <CheckBox Content="Use custom credentials for this server"
                              IsChecked="{Binding UseCustomCredentials}" Margin="0,0,0,10"
                              Checked="ServerField_Changed" Unchecked="ServerField_Changed"/>
                    <StackPanel IsEnabled="{Binding UseCustomCredentials}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Username" Style="{DynamicResource FieldLabel}"/>
                                <TextBox Text="{Binding CustomUsername, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource FormTextBox}" TextChanged="ServerField_Changed"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Password" Style="{DynamicResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0">
                                    <PasswordBox x:Name="CustomPasswordHidden"
                                                 Style="{DynamicResource FormPasswordBox}"
                                                 PasswordChanged="CustomPasswordHidden_PasswordChanged"/>
                                    <TextBox x:Name="CustomPasswordVisible"
                                             Text="{Binding CustomPassword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{DynamicResource FormTextBox}"
                                             TextChanged="ServerField_Changed"
                                             Visibility="Collapsed"/>
                                </Grid>
                                    <ToggleButton x:Name="RevealCustomPasswordToggle" Grid.Column="1"
                                                  Style="{DynamicResource PasswordRevealToggle}"
                                                  Checked="RevealCustomPasswordToggle_Changed"
                                                  Unchecked="RevealCustomPasswordToggle_Changed"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Private Key (optional)" Style="{DynamicResource FieldLabel}"/>
                                <TextBox Text="{Binding PrivateKeyPath, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{DynamicResource FormTextBox}" IsReadOnly="True"
                                         TextChanged="ServerField_Changed"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Browse" Style="{DynamicResource SecondaryButton}"
                                    VerticalAlignment="Bottom" Margin="8,0,0,0"
                                    Command="{Binding DataContext.BrowsePrivateKeyCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Grid Grid.Row="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Commands" Style="{DynamicResource SectionTitle}" Margin="0,0,0,8"/>
                <Border Grid.Row="1" Background="{DynamicResource BgDarkBrush}" CornerRadius="8" Padding="4"
                        MinHeight="140" MaxHeight="220">
                    <ListBox x:Name="CommandListBox" Grid.Row="1" ItemsSource="{Binding Commands}"
                             SelectedItem="{Binding DataContext.SelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                             Style="{DynamicResource FlatListBox}"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent" BorderThickness="0"
                                         FontFamily="{DynamicResource MonoFont}" FontSize="12"
                                         MinHeight="32" Padding="4,6"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         PreviewKeyDown="CommandTextBox_PreviewKeyDown"
                                         TextChanged="CommandField_Changed"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,4">
                    <Button Content="+ Add" Style="{DynamicResource PrimaryButton}" Margin="0,0,4,0"
                            Command="{Binding DataContext.AddCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="Remove" Style="{DynamicResource DangerButton}" Margin="0,0,4,0"
                            Command="{Binding DataContext.RemoveCommandCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="▲" Style="{DynamicResource IconButton}"
                            Command="{Binding DataContext.MoveCommandUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    <Button Content="▼" Style="{DynamicResource IconButton}"
                            Command="{Binding DataContext.MoveCommandDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
